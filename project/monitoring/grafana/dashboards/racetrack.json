{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "refresh": "5s",
  "tags": ["racetrack", "f1"],
  "title": "RaceTrack — F1 Telemetry",
  "uid": "racetrack-f1",
  "time": { "from": "now-15m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "simulation_id",
        "label": "Simulación",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "racetrack-prometheus" },
        "query": { "query": "query_result(f1_simulation_info)", "refId": "StandardVariableQuery" },
        "regex": "/session_id=\"(?<text>[^\"]+)\".*simulation_id=\"(?<value>[^\"]+)\"/",
        "refresh": 2,
        "sort": 0,
        "includeAll": false,
        "multi": false,
        "current": {}
      },
      {
        "name": "driver",
        "label": "Pilotos",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "racetrack-prometheus" },
        "query": { "query": "label_values(f1_driver_position{simulation_id=\"$simulation_id\"}, driver_id)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "sort": 3,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "type": "stat", "title": "Sesión", "id": 1,
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "racetrack-prometheus" },
      "targets": [ { "refId": "A", "expr": "f1_simulation_info{simulation_id=\"$simulation_id\"}", "legendFormat": "{{session_id}}", "instant": true } ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "name", "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "purple" }, "mappings": [ { "type": "value", "options": { "9094": {"text": "Mónaco"}, "9165": {"text": "Singapur"}, "9157": {"text": "Monza"}, "9158": {"text": "Monza (9158)"}, "9126": {"text": "Silverstone"}, "9141": {"text": "Spa"}, "9173": {"text": "Suzuka"}, "9205": {"text": "Brasil"}, "9189": {"text": "Las Vegas"}, "9118": {"text": "Austria"} } } ] } }
    },
    {
      "type": "stat", "title": "Estado", "id": 2,
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "racetrack-prometheus" },
      "targets": [ { "refId": "A", "expr": "f1_simulation_complete{simulation_id=\"$simulation_id\"}", "instant": true } ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "mappings": [ { "type": "value", "options": { "0": {"text": "EN CARRERA", "color": "green", "index": 0}, "1": {"text": "FINISHED", "color": "blue", "index": 1} } } ], "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ {"color": "green", "value": null} ] } } }
    },
    {
      "type": "gauge", "title": "Progreso", "id": 3,
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "racetrack-prometheus" },
      "targets": [ { "refId": "A", "expr": "f1_simulation_progress_ratio{simulation_id=\"$simulation_id\"}", "instant": true } ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "showThresholdMarkers": true },
      "fieldConfig": { "defaults": { "min": 0, "max": 1, "unit": "percentunit", "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ {"color": "blue", "value": null}, {"color": "green", "value": 0.99} ] } } }
    },
    {
      "type": "stat", "title": "Tiempo de carrera", "id": 4,
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "racetrack-prometheus" },
      "targets": [ { "refId": "A", "expr": "f1_simulation_race_time_seconds{simulation_id=\"$simulation_id\"}", "instant": true } ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "dtdhms", "color": { "mode": "fixed", "fixedColor": "text" } } }
    },
    {
      "type": "stat", "title": "Vuelta (líder)", "id": 5,
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "racetrack-prometheus" },
      "targets": [ { "refId": "A", "expr": "max(f1_driver_lap_number{simulation_id=\"$simulation_id\"})", "instant": true } ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "color": { "mode": "fixed", "fixedColor": "text" } } }
    },
    {
      "type": "stat", "title": "Pilotos", "id": 6,
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "racetrack-prometheus" },
      "targets": [ { "refId": "A", "expr": "count(f1_driver_position{simulation_id=\"$simulation_id\"})", "instant": true } ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0, "color": { "mode": "fixed", "fixedColor": "text" } } }
    },
    {
      "type": "row", "title": "Clasificación / Resultado final", "id": 50,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 4 }
    },
    {
      "type": "table", "title": "Clasificación (en vivo · al Finished = resultado final)", "id": 10,
      "gridPos": { "h": 11, "w": 24, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "racetrack-prometheus" },
      "targets": [
        { "refId": "A", "expr": "f1_driver_position{simulation_id=\"$simulation_id\", driver_id=~\"$driver\"}", "format": "table", "instant": true },
        { "refId": "B", "expr": "f1_driver_lap_number{simulation_id=\"$simulation_id\", driver_id=~\"$driver\"}", "format": "table", "instant": true },
        { "refId": "C", "expr": "f1_driver_gap_to_leader_seconds{simulation_id=\"$simulation_id\", driver_id=~\"$driver\"}", "format": "table", "instant": true },
        { "refId": "D", "expr": "f1_driver_last_lap_seconds{simulation_id=\"$simulation_id\", driver_id=~\"$driver\"}", "format": "table", "instant": true },
        { "refId": "E", "expr": "f1_driver_speed_kmh{simulation_id=\"$simulation_id\", driver_id=~\"$driver\"}", "format": "table", "instant": true }
      ],
      "transformations": [
        { "id": "joinByField", "options": { "byField": "driver_id", "mode": "outer" } },
        { "id": "organize", "options": {
          "excludeByName": { "Time": true, "Time 1": true, "Time 2": true, "Time 3": true, "Time 4": true, "Time 5": true, "__name__": true, "__name__ 1": true, "__name__ 2": true, "__name__ 3": true, "__name__ 4": true, "__name__ 5": true, "job": true, "job 1": true, "job 2": true, "job 3": true, "job 4": true, "job 5": true, "instance": true, "instance 1": true, "instance 2": true, "instance 3": true, "instance 4": true, "instance 5": true, "simulation_id": true, "simulation_id 1": true, "simulation_id 2": true, "simulation_id 3": true, "simulation_id 4": true, "simulation_id 5": true },
          "renameByName": { "Value #A": "Pos", "Value #B": "Vuelta", "Value #C": "Gap", "Value #D": "Última vuelta", "Value #E": "Vel (km/h)", "driver_id": "Piloto" },
          "indexByName": { "Value #A": 0, "driver_id": 1, "Value #B": 2, "Value #C": 3, "Value #D": 4, "Value #E": 5 }
        } },
        { "id": "sortBy", "options": { "fields": {}, "sort": [ { "field": "Pos", "desc": false } ] } }
      ],
      "options": { "showHeader": true, "cellHeight": "md", "footer": { "show": false } },
      "fieldConfig": {
        "defaults": { "custom": { "align": "left", "cellOptions": { "type": "auto" } } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Piloto" }, "properties": [
            { "id": "custom.width", "value": 230 },
            { "id": "mappings", "value": [ { "type": "value", "options": {
              "1": {"text": "#1 Verstappen · Red Bull"}, "11": {"text": "#11 Pérez · Red Bull"},
              "44": {"text": "#44 Hamilton · Mercedes"}, "63": {"text": "#63 Russell · Mercedes"},
              "16": {"text": "#16 Leclerc · Ferrari"}, "55": {"text": "#55 Sainz · Ferrari"},
              "4": {"text": "#4 Norris · McLaren"}, "81": {"text": "#81 Piastri · McLaren"},
              "14": {"text": "#14 Alonso · Aston Martin"}, "18": {"text": "#18 Stroll · Aston Martin"},
              "10": {"text": "#10 Gasly · Alpine"}, "31": {"text": "#31 Ocon · Alpine"},
              "23": {"text": "#23 Albon · Williams"}, "2": {"text": "#2 Sargeant · Williams"},
              "22": {"text": "#22 Tsunoda · AlphaTauri"}, "21": {"text": "#21 De Vries · AlphaTauri"},
              "3": {"text": "#3 Ricciardo · AlphaTauri"}, "40": {"text": "#40 Lawson · AlphaTauri"},
              "77": {"text": "#77 Bottas · Alfa Romeo"}, "24": {"text": "#24 Zhou · Alfa Romeo"},
              "20": {"text": "#20 Magnussen · Haas"}, "27": {"text": "#27 Hülkenberg · Haas"}
            } } ] }
          ] },
          { "matcher": { "id": "byName", "options": "Pos" }, "properties": [
            { "id": "custom.width", "value": 70 },
            { "id": "decimals", "value": 0 },
            { "id": "custom.cellOptions", "value": { "type": "color-background" } },
            { "id": "color", "value": { "mode": "continuous-GrYlRd" } }
          ] },
          { "matcher": { "id": "byName", "options": "Vel (km/h)" }, "properties": [
            { "id": "unit", "value": "velocitykmh" }, { "id": "decimals", "value": 0 },
            { "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "gradient" } },
            { "id": "max", "value": 350 }, { "id": "min", "value": 0 }
          ] },
          { "matcher": { "id": "byName", "options": "Gap" }, "properties": [
            { "id": "unit", "value": "s" }, { "id": "decimals", "value": 1 },
            { "id": "mappings", "value": [ { "type": "value", "options": { "0": {"text": "LÍDER", "color": "green"} } } ] }
          ] },
          { "matcher": { "id": "byName", "options": "Última vuelta" }, "properties": [ { "id": "unit", "value": "s" }, { "id": "decimals", "value": 1 } ] },
          { "matcher": { "id": "byName", "options": "Vuelta" }, "properties": [ { "id": "decimals", "value": 0 } ] }
        ]
      }
    },
    {
      "type": "row", "title": "Posiciones y velocidad", "id": 51,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 }
    },
    {
      "type": "timeseries", "title": "Posiciones en carrera (P1 arriba)", "id": 20,
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "racetrack-prometheus" },
      "targets": [ { "refId": "A", "expr": "f1_driver_position{simulation_id=\"$simulation_id\", driver_id=~\"$driver\"}", "legendFormat": "#{{driver_id}}" } ],
      "fieldConfig": { "defaults": { "min": 1, "max": 20, "decimals": 0, "custom": { "drawStyle": "line", "lineWidth": 2, "showPoints": "never", "axisInverted": true } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "right", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "asc" } }
    },
    {
      "type": "timeseries", "title": "Velocidad (km/h)", "id": 21,
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 17 },
      "datasource": { "type": "prometheus", "uid": "racetrack-prometheus" },
      "targets": [ { "refId": "A", "expr": "f1_driver_speed_kmh{simulation_id=\"$simulation_id\", driver_id=~\"$driver\"}", "legendFormat": "#{{driver_id}}" } ],
      "fieldConfig": { "defaults": { "min": 0, "max": 350, "unit": "velocitykmh", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 5, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "right", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } }
    },
    {
      "type": "row", "title": "Gap al líder", "id": 52,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 }
    },
    {
      "type": "timeseries", "title": "Gap al líder (s)", "id": 22,
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 27 },
      "datasource": { "type": "prometheus", "uid": "racetrack-prometheus" },
      "targets": [ { "refId": "A", "expr": "f1_driver_gap_to_leader_seconds{simulation_id=\"$simulation_id\", driver_id=~\"$driver\"}", "legendFormat": "#{{driver_id}}" } ],
      "fieldConfig": { "defaults": { "min": 0, "unit": "s", "custom": { "drawStyle": "line", "lineWidth": 2, "showPoints": "never" } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "right", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "asc" } }
    }
  ]
}
